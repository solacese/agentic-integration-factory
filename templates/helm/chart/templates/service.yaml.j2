apiVersion: v1
kind: Service
metadata:
  name: {{ service_name }}-integration
spec:
  selector:
    app: {{ service_name }}-integration
  ports:
    - port: {{ "{{" }} .Values.service.port {{ "}}" }}
      targetPort: {{ "{{" }} .Values.service.targetPort {{ "}}" }}
      protocol: TCP
      name: http

