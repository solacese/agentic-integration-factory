# --------------------------
# RUNTIME CONFIGURATION
# Generated by Agentic Integration Factory
# Maps workflows to actual Solace destinations
# --------------------------

spring:
  cloud:
    stream:
      bindings:
{% for workflow in workflows %}
        input-{{ workflow.index }}:
          binder: {{ workflow.input_binder }}
{% if workflow.input_destination %}
          destination: {{ workflow.input_destination }}
{% endif %}
        output-{{ workflow.index }}:
          binder: solace
          destination: {{ workflow.output_destination }}
{% endfor %}
      solace:
        default:
          producer:
            destination-type: topic

solace:
  connector:
    workflows:
{% for workflow in workflows %}
      {{ workflow.index }}:
        enabled: true
        transform:
          source-payload:
            content-type: application/json
          target-payload:
            content-type: application/json
{% endfor %}

logging:
  level:
    root: INFO
    com.solace.connector.core: DEBUG
    com.solace.spring.cloud.stream.binder: DEBUG
