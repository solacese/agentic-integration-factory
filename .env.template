# Agentic Integration Factory
# Copy this file to .env for a local or hosted agent run.

# Core platform
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000
APP_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
DATABASE_URL=postgresql+psycopg://spec2event:spec2event@localhost:5432/spec2event
REDIS_URL=redis://localhost:6379/0
APP_ENCRYPTION_KEY=replace-with-32-byte-base64-key
DEMO_ADMIN_PASSWORD=replace-me
ALLOW_INSECURE_LOCAL_LOGIN=false
WORKSPACE_ROOT=./workspace
RUNS_ROOT=./generated-runs
MDK_SAMPLE_ROOT=./mdk-reference/micro-integration
ENABLE_RQ=false
LOG_LEVEL=INFO

# Main execution mode
SOURCE_MODE=openapi
DEPLOYMENT_TARGET=ec2
EVENT_TRANSPORT=solace
GOVERNANCE_TARGET=event_portal

# AWS and runtime deployment
AWS_REGION=ca-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
ECR_REPOSITORY_NAME=spec2event-generated-integrations
CONTROL_PLANE_SECURITY_GROUP_ID=
CONTROL_PLANE_SUBNET_ID=
CONTROL_PLANE_VPC_ID=
EPHEMERAL_EC2_TTL_MINUTES=60
PUBLIC_BASE_URL=

# Optional direct EC2 target
DEPLOY_EC2_HOST=
DEPLOY_EC2_SSH_USER=ec2-user
DEPLOY_EC2_SSH_PRIVATE_KEY=
DEPLOY_EC2_PORT=22

# Optional Kubernetes or Rancher target
K8S_API_SERVER=
K8S_TOKEN=
K8S_NAMESPACE=default
K8S_CA_CERT=
RANCHER_URL=
RANCHER_TOKEN=

# Container registry
CONTAINER_REGISTRY=
CONTAINER_REGISTRY_USERNAME=
CONTAINER_REGISTRY_PASSWORD=
CONTAINER_IMAGE_PREFIX=ghcr.io/example/spec2event

# Solace PubSub+ runtime transport
SOLACE_BROKER_URL=
SOLACE_VPN=
SOLACE_USERNAME=
SOLACE_PASSWORD=
SOLACE_WEB_MESSAGING_URL=

# Solace Event Portal
EVENT_PORTAL_BASE_URL=
EVENT_PORTAL_TOKEN=
EVENT_PORTAL_ORG_ID=
EVENT_PORTAL_DOMAIN_ID=
EVENT_PORTAL_RUNTIME_REGION=

# Optional schema or SerDes registry
SERDES_REGISTRY_URL=
SERDES_REGISTRY_TYPE=
SERDES_REGISTRY_API_KEY=
SERDES_REGISTRY_USERNAME=
SERDES_REGISTRY_PASSWORD=

# AI refinement endpoint
LITELLM_BASE_URL=
LITELLM_API_KEY=
LITELLM_MODEL=

# OpenAPI or source-system starting point
SOURCE_MODE=openapi
SOURCE_OPENAPI_FILE=
SOURCE_OPENAPI_URL=
SOURCE_API_BASE_URL=
SOURCE_API_KEY=
SOURCE_API_AUTH_TYPE=

# Database discovery starting point
SOURCE_DATABASE_KIND=postgres
SOURCE_DATABASE_HOST=
SOURCE_DATABASE_PORT=5432
SOURCE_DATABASE_NAME=
SOURCE_DATABASE_SCHEMA=public
SOURCE_DATABASE_USERNAME=
SOURCE_DATABASE_PASSWORD=
SOURCE_DATABASE_SSLMODE=require

# Optional webhook or provider credentials
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
