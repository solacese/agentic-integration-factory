# Agentic Integration Factory
# Demo configuration for the simple OpenAPI plus PostgreSQL -> EC2 -> Event Portal path.
#
# Hybrid demo configuration:
# - OpenAPI contract: petstore.yaml
# - PostgreSQL source: public.products
# - deployment target: temporary EC2
# - event transport: Solace PubSub+
# - governance target: Solace Event Portal
#
# Connectivity notes:
# - PostgreSQL connectivity was verified successfully on 2026-03-19.
# - The cleanest database story is the public.products table.
# - Refresh EVENT_PORTAL_TOKEN if the current token is still rejected by the API.

# Core platform
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000
APP_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
DATABASE_URL=postgresql+psycopg://spec2event:spec2event@localhost:5432/spec2event
REDIS_URL=redis://localhost:6379/0
APP_ENCRYPTION_KEY=CHANGE_ME_generate_with_python_c_import_cryptography_fernet_Fernet_generate_key
DEMO_ADMIN_PASSWORD=changeme
ALLOW_INSECURE_LOCAL_LOGIN=true
WORKSPACE_ROOT=./workspace
RUNS_ROOT=./generated-runs
MDK_SAMPLE_ROOT=./mdk-reference/micro-integration
ENABLE_RQ=false
LOG_LEVEL=INFO

# Main execution mode
SOURCE_MODE=multi
SOURCE_MULTI_MODES=openapi,database
SOURCE_ADAPTER_MODE=auto
DEPLOYMENT_TARGET=ec2
EVENT_TRANSPORT=solace
GOVERNANCE_TARGET=event_portal

# AWS and runtime deployment
AWS_REGION=ca-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
ECR_REPOSITORY_NAME=agentic-integration-factory-generated-integrations
CONTROL_PLANE_SECURITY_GROUP_ID=
CONTROL_PLANE_SUBNET_ID=
CONTROL_PLANE_VPC_ID=
EPHEMERAL_EC2_TTL_MINUTES=60
PUBLIC_BASE_URL=

# Optional direct EC2 target
DEPLOY_EC2_HOST=
DEPLOY_EC2_SSH_USER=ec2-user
DEPLOY_EC2_SSH_PRIVATE_KEY=
DEPLOY_EC2_PORT=22

# Optional Kubernetes or Rancher target
K8S_API_SERVER=
K8S_TOKEN=
K8S_NAMESPACE=default
K8S_CA_CERT=
RANCHER_URL=
RANCHER_TOKEN=

# Container registry
CONTAINER_REGISTRY=
CONTAINER_REGISTRY_USERNAME=
CONTAINER_REGISTRY_PASSWORD=
CONTAINER_IMAGE_PREFIX=ghcr.io/example/spec2event

# Solace PubSub+ runtime transport
SOLACE_BROKER_URL=
SOLACE_VPN=
SOLACE_USERNAME=default
SOLACE_PASSWORD=default
SOLACE_WEB_MESSAGING_URL=

# Solace Event Portal
EVENT_PORTAL_BASE_URL=https://solace-sso.solace.cloud/ep/designer
EVENT_PORTAL_TOKEN=
EVENT_PORTAL_ORG_ID=
EVENT_PORTAL_DOMAIN_ID=
EVENT_PORTAL_RUNTIME_REGION=

# Optional schema or SerDes registry
SERDES_REGISTRY_URL=
SERDES_REGISTRY_TYPE=
SERDES_REGISTRY_API_KEY=
SERDES_REGISTRY_USERNAME=
SERDES_REGISTRY_PASSWORD=

# AI refinement endpoint
LITELLM_BASE_URL=
LITELLM_API_KEY=
LITELLM_MODEL=claude-opus-4-6

# OpenAPI source
SOURCE_OPENAPI_FILE=./samples/openapi/petstore.yaml
SOURCE_OPENAPI_URL=
SOURCE_API_BASE_URL=
SOURCE_API_KEY=
SOURCE_API_AUTH_TYPE=
SOURCE_GRAPHQL_URL=
SOURCE_GRPC_ENDPOINT=
SOURCE_WEBHOOK_PUBLIC_URL=
SOURCE_WEBHOOK_SIGNATURE_HEADER=
SOURCE_SAAS_VENDOR=

# File or batch source starting point
SOURCE_FILE_PATH=
SOURCE_FILE_GLOB=
SOURCE_FILE_FORMAT=
SOURCE_FILE_ENCODING=utf-8
SOURCE_FILE_DELIMITER=,
SOURCE_FILE_HAS_HEADER=true
SOURCE_FILE_POLL_INTERVAL_SECONDS=60
SOURCE_FILE_ARCHIVE_PATH=
SOURCE_FILE_QUARANTINE_PATH=
SOURCE_FILE_IDEMPOTENCY_MODE=filename_hash

# MQTT source starting point
SOURCE_MQTT_HOST=
SOURCE_MQTT_PORT=8883
SOURCE_MQTT_TLS=true
SOURCE_MQTT_CLIENT_ID=
SOURCE_MQTT_USERNAME=
SOURCE_MQTT_PASSWORD=
SOURCE_MQTT_TOPIC_FILTERS=
SOURCE_MQTT_QOS=1
SOURCE_MQTT_CLEAN_SESSION=false

# Kafka source starting point
SOURCE_KAFKA_BOOTSTRAP_SERVERS=
SOURCE_KAFKA_SECURITY_PROTOCOL=
SOURCE_KAFKA_SASL_MECHANISM=
SOURCE_KAFKA_USERNAME=
SOURCE_KAFKA_PASSWORD=
SOURCE_KAFKA_TOPICS=
SOURCE_KAFKA_CONSUMER_GROUP=
SOURCE_KAFKA_START_OFFSET=latest

# AMQP, JMS, or queue source starting point
SOURCE_AMQP_URL=
SOURCE_AMQP_USERNAME=
SOURCE_AMQP_PASSWORD=
SOURCE_AMQP_QUEUE=
SOURCE_AMQP_TOPIC=
SOURCE_JMS_CONNECTION_FACTORY=
SOURCE_JMS_DESTINATION=
SOURCE_QUEUE_NAME=
SOURCE_QUEUE_ACK_MODE=client

# SFTP or FTP source starting point
SOURCE_SFTP_HOST=
SOURCE_SFTP_PORT=22
SOURCE_SFTP_USERNAME=
SOURCE_SFTP_PASSWORD=
SOURCE_SFTP_PRIVATE_KEY=
SOURCE_SFTP_PATH=
SOURCE_FTP_HOST=
SOURCE_FTP_PORT=21
SOURCE_FTP_USERNAME=
SOURCE_FTP_PASSWORD=
SOURCE_FTP_PATH=

# Object storage source starting point
SOURCE_OBJECT_STORAGE_PROVIDER=
SOURCE_OBJECT_STORAGE_BUCKET=
SOURCE_OBJECT_STORAGE_PREFIX=
SOURCE_OBJECT_STORAGE_REGION=
SOURCE_OBJECT_STORAGE_ACCESS_KEY=
SOURCE_OBJECT_STORAGE_SECRET_KEY=

# Database source
SOURCE_DATABASE_URL=
SOURCE_DATABASE_KIND=postgres
SOURCE_DATABASE_HOST=
SOURCE_DATABASE_PORT=5432
SOURCE_DATABASE_NAME=
SOURCE_DATABASE_SCHEMA=public
SOURCE_DATABASE_USERNAME=
SOURCE_DATABASE_PASSWORD=
SOURCE_DATABASE_SSLMODE=require

# Optional custom source notes
SOURCE_CUSTOM_TYPE=
SOURCE_CUSTOM_DESCRIPTION=
SOURCE_CUSTOM_SCHEMA_FILE=
