package com.spec2event.generated.service;

import com.fasterxml.jackson.databind.JsonNode;
import org.springframework.messaging.support.MessageBuilder;
import org.springframework.stereotype.Service;
import org.springframework.cloud.stream.function.StreamBridge;

import java.time.Instant;
import java.util.ArrayList;
import java.util.LinkedHashMap;
import java.util.List;
import java.util.Map;

@Service
public class SolacePublisherService {

    private final StreamBridge streamBridge;

    public SolacePublisherService(StreamBridge streamBridge) {
        this.streamBridge = streamBridge;
    }

    public List<String> publish(
            List<CanonicalEventService.EventBlueprint> blueprints,
            JsonNode payload,
            String correlationId,
            String sourceOperationId
    ) {
        List<String> publishedTopics = new ArrayList<>();
        for (CanonicalEventService.EventBlueprint blueprint : blueprints) {
            Map<String, Object> envelope = new LinkedHashMap<>();
            envelope.put("eventName", blueprint.eventName());
            envelope.put("schemaName", blueprint.schemaName());
            envelope.put("applicationName", blueprint.applicationName());
            envelope.put("sourceOperationId", sourceOperationId);
            envelope.put("correlationId", correlationId);
            envelope.put("occurredAt", Instant.now().toString());
            envelope.put("payload", payload);
            streamBridge.send(
                    blueprint.bindingName(),
                    MessageBuilder.withPayload(envelope)
                            .setHeader("correlationId", correlationId)
                            .setHeader("eventName", blueprint.eventName())
                            .build()
            );
            publishedTopics.add(blueprint.topicName());
        }
        return publishedTopics;
    }
}

