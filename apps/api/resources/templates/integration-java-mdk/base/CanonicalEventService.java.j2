package com.spec2event.generated.service;

import com.fasterxml.jackson.databind.JsonNode;
import org.springframework.stereotype.Service;

import java.util.LinkedHashMap;
import java.util.List;
import java.util.Map;

@Service
public class CanonicalEventService {

    public record EventBlueprint(
            String bindingName,
            String topicName,
            String eventName,
            String schemaName,
            String applicationName
    ) {}

    private static final Map<String, List<EventBlueprint>> OPERATION_EVENTS = new LinkedHashMap<>();

    static {
{% for operation in operations if operation.eventCandidates %}
        OPERATION_EVENTS.put("{{ operation.operationId }}", List.of(
{% for event in operation.eventCandidates %}
                new EventBlueprint(
                        "{{ event.bindingName }}",
                        "{{ event.topicName }}",
                        "{{ event.canonicalEventName }}",
                        "{{ event.schemaName }}",
                        "{{ event.applicationName }}"
                ){% if not loop.last %},{% endif %}
{% endfor %}
        ));
{% endfor %}
    }

    public List<EventBlueprint> planForOperation(String operationId, JsonNode payload) {
        if ("stripe-webhook-payment".equals(operationId)) {
            return planStripeEvents(payload);
        }
        return OPERATION_EVENTS.getOrDefault(operationId, List.of());
    }

    private List<EventBlueprint> planStripeEvents(JsonNode payload) {
        String stripeType = payload != null && payload.hasNonNull("type") ? payload.get("type").asText() : "";
        return switch (stripeType) {
            case "payment_intent.succeeded" -> List.of(new EventBlueprint(
                    "stripePaymentIntentSucceeded",
                    "payments/stripe/payment_intent/succeeded/v1",
                    "StripePaymentIntentSucceeded",
                    "StripePaymentIntentSucceededPayload",
                    "{{ application_name }}"
            ));
            case "payment_intent.payment_failed" -> List.of(new EventBlueprint(
                    "stripePaymentIntentFailed",
                    "payments/stripe/payment_intent/failed/v1",
                    "StripePaymentIntentFailed",
                    "StripePaymentIntentFailedPayload",
                    "{{ application_name }}"
            ));
            case "charge.refunded" -> List.of(new EventBlueprint(
                    "stripeChargeRefunded",
                    "payments/stripe/charge/refunded/v1",
                    "StripeChargeRefunded",
                    "StripeChargeRefundedPayload",
                    "{{ application_name }}"
            ));
            default -> List.of();
        };
    }
}

